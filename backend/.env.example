# MongoDB
# Вариант 1 (по спецификации): MongoDB Atlas M0 Free — см. docs/setup_guide.md
# MONGODB_URL=mongodb+srv://user:password@cluster.mongodb.net/
# Вариант 2: локальный MongoDB (тоже бесплатно, работает без интернета)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=local_services_map

# JWT — сгенерируйте свой ключ: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-super-secret-key-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# MapTiler (опционально!). Если ключ не указан, приложение автоматически
# использует бесплатные тайлы OpenStreetMap — карта всё равно работает.
MAPTILER_API_KEY=

# Кеш Overpass API (в днях)
CACHE_TTL_DAYS=7

# Режим разработки
DEBUG=true
